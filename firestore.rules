rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user is an admin if they own a document in admins/{uid} — that document can
    // only be created manually in the Firebase Console, never by client code.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isNum(val) {
      return val is int || val is float;
    }

    // Structural checks shared by create and update (does not constrain createdAt,
    // since on update createdAt must stay equal to its original value, not "now").
    function isValidUserFields(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'gender', 'phone', 'email', 'role', 'createdAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 30
        && data.firstName is string && data.firstName.size() >= 1 && data.firstName.size() <= 100
        // lastName may be empty — a guest completing a booking only has to give a first name and email.
        && data.lastName is string && data.lastName.size() <= 100
        && data.gender in ['homme', 'femme', 'autre']
        && data.phone is string && data.phone.size() <= 20 && (data.phone.size() == 0 || data.phone.size() >= 8)
        && data.email is string && data.email.size() <= 200
        && data.role in ['client', 'barber']
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 500))
        && (!('city' in data) || (data.city is string && data.city.size() <= 50))
        && (!('avatarUrl' in data) || data.avatarUrl is string)
        && (!('coverUrl' in data) || data.coverUrl is string)
        && (!('portfolioItems' in data) || (data.portfolioItems is list && data.portfolioItems.size() <= 60))
        && (!('categories' in data) || (data.categories is list && data.categories.size() <= 20))
        && (!('services' in data) || (data.services is list && data.services.size() <= 30))
        && (!('workingDays' in data) || data.workingDays is list)
        && (!('workStartHour' in data) || isNum(data.workStartHour))
        && (!('workEndHour' in data) || isNum(data.workEndHour))
        && (!('basePrice' in data) || isNum(data.basePrice))
        && (!('nightEnabled' in data) || data.nightEnabled is bool)
        && (!('nightStartHour' in data) || isNum(data.nightStartHour))
        && (!('nightPrice' in data) || isNum(data.nightPrice))
        && (!('kycStatus' in data) || data.kycStatus in ['unverified', 'pending', 'verified'])
        && (!('unpaidCommissionsCount' in data) || isNum(data.unpaidCommissionsCount))
        && (!('totalCommissionsOwed' in data) || isNum(data.totalCommissionsOwed));
      // Note: the CIN/selfie file URLs live in kycSubmissions/{uid}, not here — this
      // users document is publicly readable (guests browse profiles), so it must never
      // hold a link to someone's identity documents.
    }

    // A brand new account may only self-declare as unverified/pending (never
    // 'verified') and must start with zero commission debt.
    function isValidKycOnCreate(data) {
      return (!('kycStatus' in data) || data.kycStatus in ['unverified', 'pending'])
        && (!('unpaidCommissionsCount' in data) || data.unpaidCommissionsCount == 0)
        && (!('totalCommissionsOwed' in data) || data.totalCommissionsOwed == 0);
    }

    function isValidNewUser(data) {
      return isValidUserFields(data) && data.createdAt == request.time && isValidKycOnCreate(data);
    }

    // The owner may submit a KYC dossier (unverified/none -> pending) but can never
    // grant themselves 'verified' status this way.
    function isSubmittingKyc(before, after) {
      return (!('kycStatus' in before) || before.kycStatus != 'verified')
        && after.kycStatus == 'pending';
    }

    function isValidKycSubmission(data) {
      return data.keys().hasAll(['cinUrl', 'selfieUrl', 'submittedAt'])
        && data.keys().size() == 3
        && data.cinUrl is string && data.cinUrl.size() > 0
        && data.selfieUrl is string && data.selfieUrl.size() > 0
        && data.submittedAt == request.time;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'duration', 'category'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0
        && isNum(data.price) && data.price >= 0
        && isNum(data.duration) && data.duration > 0
        && data.category is string;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'serviceId', 'dateTime', 'status', 'totalPrice'])
        && data.keys().size() >= 6 && data.keys().size() <= 14
        && data.clientId == request.auth.uid
        && data.barberId is string
        && data.serviceId is string
        && data.status in ['pending', 'confirmed', 'cancelled', 'completed']
        && isNum(data.totalPrice);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'appointmentId', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 6
        && data.clientId == request.auth.uid
        && isNum(data.rating) && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // User profiles — barber profiles are public (clients browse prestations/profiles
    // without an account) but non-barber profiles (other clients) stay signed-in-only.
    match /users/{userId} {
      allow get: if isSignedIn() || resource.data.role == 'barber';
      allow list: if isSignedIn() || resource.data.role == 'barber';
      allow create: if isOwner(userId) && isValidNewUser(request.resource.data);

      // The owner can update everything about their own profile EXCEPT KYC/commission
      // fields, which they can only move from unverified/none -> pending (submitting a
      // dossier) — never to 'verified', and never touch the commission fields at all.
      // Only an admin (see isAdmin() above) can grant 'verified' or settle a commission
      // balance, which is what makes the "vérifié" badge and commission debt trustworthy.
      allow update: if
        (isOwner(userId)
          && isValidUserFields(request.resource.data)
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['kycStatus', 'unpaidCommissionsCount', 'totalCommissionsOwed'])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kycStatus'])
              && isSubmittingKyc(resource.data, request.resource.data)
            )
          )
        )
        || (isAdmin()
          && resource.data.role == 'barber'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kycStatus', 'unpaidCommissionsCount', 'totalCommissionsOwed'])
          && request.resource.data.kycStatus in ['unverified', 'pending', 'verified']
          && isNum(request.resource.data.unpaidCommissionsCount)
          && isNum(request.resource.data.totalCommissionsOwed)
        );
    }

    // Admin allowlist — one document per admin UID, created manually in the Firebase
    // Console only (never writable by client code). A user may read their own doc to
    // decide whether to show the admin panel, but cannot list others or write at all.
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }

    // KYC dossiers (CIN + selfie URLs) — kept out of the public users/ document on
    // purpose. Only the barber themself and admins can read it.
    match /kycSubmissions/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidKycSubmission(request.resource.data);
    }

    // Services (Menu) — public so guests can browse prestations before signing in.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSignedIn(); // For now allow write to seed, should be restricted later
    }

    // Real daily visitor counter — public (guests must be counted too), but write is
    // restricted to a strict +1 delta on a single 'count' field so it can never be
    // tampered into an arbitrary number even without auth.
    match /stats/{statId} {
      allow read: if true;
      allow create: if statId.matches('^visits_[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if statId.matches('^visits_[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count'])
        && request.resource.data.count == resource.data.count + 1;
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber');
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber');
      allow create: if isSignedIn() && isValidAppointment(request.resource.data);
      allow update: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'totalPrice', 'proposedPrice', 'counterPriceByBarber', 'counterDateTime', 'dateTime', 'negotiationStatus', 'clientLocationShared', 'clientNotes', 'barberId'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['barberId'])
          || (resource.data.barberId == 'dummy_barber' && request.resource.data.barberId == request.auth.uid)
        );
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReview(request.resource.data);
      allow delete: if isSignedIn() && resource.data.clientId == request.auth.uid;
    }
  }
}
