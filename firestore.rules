rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user is an admin if they own a document in admins/{uid} — that document can
    // only be created manually in the Firebase Console, never by client code.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isNum(val) {
      return val is int || val is float;
    }

    // Server-side backstop against a pro pasting a phone number / WhatsApp link / email
    // into a public text field to book clients off-platform (bypassing the commission) —
    // mirrors the client-side check in src/utils/contactInfoFilter.ts. Only usable on a
    // single string field (bio); Firestore rules can't loop over portfolioItems/services
    // array elements, so those rely on the client-side check alone. Zero-tolerance on
    // digits (2+ anywhere in the text, not necessarily consecutive) — a long-unbroken-run
    // check is trivially beaten by breaking a number up with letters ("07 80 9OH9OH9OH9O").
    function hasContactInfo(text) {
      return text.matches('(?s).*[0-9].*[0-9].*')
        || text.matches('(?is).*(whatsapp|wa\\.me).*')
        || text.matches('(?is).*[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}.*');
    }

    // Structural checks shared by create and update (does not constrain createdAt,
    // since on update createdAt must stay equal to its original value, not "now").
    function isValidUserFields(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'gender', 'phone', 'email', 'role', 'createdAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 30
        && data.firstName is string && data.firstName.size() >= 1 && data.firstName.size() <= 100
        // lastName may be empty — a guest completing a booking only has to give a first name and email.
        && data.lastName is string && data.lastName.size() <= 100
        && data.gender in ['homme', 'femme', 'autre']
        && data.phone is string && data.phone.size() <= 20 && (data.phone.size() == 0 || data.phone.size() >= 8)
        && data.email is string && data.email.size() <= 200
        && data.role in ['client', 'barber']
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 500 && !hasContactInfo(data.bio)))
        && (!('ageRange' in data) || data.ageRange in ['18-25', '26-35', '36-45', '46-55', '56+'])
        && (!('city' in data) || (data.city is string && data.city.size() <= 50))
        && (!('avatarUrl' in data) || data.avatarUrl is string)
        && (!('coverUrl' in data) || data.coverUrl is string)
        && (!('portfolioItems' in data) || (data.portfolioItems is list && data.portfolioItems.size() <= 60))
        && (!('categories' in data) || (data.categories is list && data.categories.size() <= 20))
        && (!('services' in data) || (data.services is list && data.services.size() <= 30))
        && (!('workingDays' in data) || data.workingDays is list)
        && (!('workStartHour' in data) || isNum(data.workStartHour))
        && (!('workEndHour' in data) || isNum(data.workEndHour))
        && (!('basePrice' in data) || isNum(data.basePrice))
        && (!('nightEnabled' in data) || data.nightEnabled is bool)
        && (!('nightStartHour' in data) || isNum(data.nightStartHour))
        && (!('nightPrice' in data) || isNum(data.nightPrice))
        && (!('kycStatus' in data) || data.kycStatus in ['unverified', 'pending', 'verified'])
        && (!('completedCount' in data) || (isNum(data.completedCount) && data.completedCount >= 0))
        && (!('profileViews' in data) || (isNum(data.profileViews) && data.profileViews >= 0))
        && (!('unpaidCommissionsCount' in data) || (isNum(data.unpaidCommissionsCount) && data.unpaidCommissionsCount >= 0))
        && (!('totalCommissionsOwed' in data) || (isNum(data.totalCommissionsOwed) && data.totalCommissionsOwed >= 0))
        && (!('reviewCount' in data) || (isNum(data.reviewCount) && data.reviewCount >= 0))
        && (!('ratingSum' in data) || (isNum(data.ratingSum) && data.ratingSum >= 0))
        && (!('locationLat' in data) || (isNum(data.locationLat) && data.locationLat >= -90 && data.locationLat <= 90))
        && (!('locationLng' in data) || (isNum(data.locationLng) && data.locationLng >= -180 && data.locationLng <= 180))
        && (!('locationMode' in data) || data.locationMode in ['manual', 'auto'])
        && (!('locationUpdatedAt' in data) || isNum(data.locationUpdatedAt))
        && (!('locationCountry' in data) || (data.locationCountry is string && data.locationCountry.size() <= 100));
      // Note: the CIN/selfie file URLs live in kycSubmissions/{uid}, not here — this
      // users document is publicly readable (guests browse profiles), so it must never
      // hold a link to someone's identity documents.
    }

    // A brand new account may only self-declare as unverified/pending, never 'verified'.
    function isValidKycOnCreate(data) {
      return !('kycStatus' in data) || data.kycStatus in ['unverified', 'pending'];
    }

    // A brand new account must start with zero commission debt — it can't pre-declare
    // itself as already owing money.
    function isValidCommissionOnCreate(data) {
      return (!('unpaidCommissionsCount' in data) || data.unpaidCommissionsCount == 0)
        && (!('totalCommissionsOwed' in data) || data.totalCommissionsOwed == 0);
    }

    function isValidNewUser(data) {
      return isValidUserFields(data) && data.createdAt == request.time && isValidKycOnCreate(data) && isValidCommissionOnCreate(data);
    }

    // The owner may submit a KYC dossier (unverified/none -> pending) but can never
    // grant themselves 'verified' status this way.
    function isSubmittingKyc(before, after) {
      return (!('kycStatus' in before) || before.kycStatus != 'verified')
        && after.kycStatus == 'pending';
    }

    function isValidKycSubmission(data) {
      return data.keys().hasAll(['cinUrl', 'selfieUrl', 'submittedAt'])
        && data.keys().size() == 3
        && data.cinUrl is string && data.cinUrl.size() > 0
        && data.selfieUrl is string && data.selfieUrl.size() > 0
        && data.submittedAt == request.time;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'duration', 'category'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0
        && isNum(data.price) && data.price >= 0
        && isNum(data.duration) && data.duration > 0
        && data.category is string;
    }

    // A full price-catalog cross-check (matching a specific service's real price on the
    // barber's profile) isn't reliably expressible in rules — services live in a list,
    // and rules can't search inside one the way they can look up a single document by
    // ID. This bounds check is a real but partial mitigation; closing the gap fully
    // needs either a services subcollection (so get() can look up one by ID) or a
    // Cloud Function, both bigger changes than a rules tweak.
    function isValidAppointment(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'serviceId', 'dateTime', 'status', 'totalPrice'])
        && data.keys().size() >= 6 && data.keys().size() <= 14
        && data.clientId == request.auth.uid
        && data.barberId is string
        && data.serviceId is string
        && data.status in ['pending', 'confirmed', 'cancelled', 'completed']
        && isNum(data.totalPrice) && data.totalPrice > 0 && data.totalPrice <= 20000
        && (!('proposedPrice' in data) || (isNum(data.proposedPrice) && data.proposedPrice > 0 && data.proposedPrice <= 20000));
    }

    function isValidMail(data) {
      return data.keys().hasOnly(['to', 'message'])
        && data.to is list && data.to.size() == 1 && data.to[0] is string && data.to[0].size() <= 200
        && data.message is map
        && data.message.keys().hasOnly(['subject', 'html'])
        && data.message.subject is string && data.message.subject.size() <= 200
        && data.message.html is string && data.message.html.size() <= 5000;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['clientId', 'barberId', 'appointmentId', 'rating', 'comment', 'createdAt'])
        && data.keys().size() == 6
        && data.clientId == request.auth.uid
        && isNum(data.rating) && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // User profiles — barber profiles are public (clients browse prestations/profiles
    // without an account); a client's own profile is readable only by themself (not by
    // every other signed-in account — a client can never list/read another client's).
    match /users/{userId} {
      allow get: if resource.data.role == 'barber' || isOwner(userId) || isAdmin();
      allow list: if resource.data.role == 'barber' || isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidNewUser(request.resource.data);

      // The owner can update everything about their own profile EXCEPT kycStatus, which
      // they can only move from unverified/none -> pending (submitting a dossier) —
      // never to 'verified' — and EXCEPT settling their own commission balance to zero.
      // Only an admin (see isAdmin() above) can grant 'verified' or settle a commission
      // balance, which is what makes the "vérifié" badge and commission debt trustworthy.
      allow update: if
        (isOwner(userId)
          && isValidUserFields(request.resource.data)
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['kycStatus'])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kycStatus'])
              && isSubmittingKyc(resource.data, request.resource.data)
            )
          )
          && (
            // completedCount ("clients servis" shown on the public profile) can only move
            // by exactly +1 in its own isolated write — the app does this right after the
            // barber marks a booking completed, never bundled with any other field change,
            // so it can't be self-inflated to an arbitrary number.
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['completedCount'])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedCount'])
              && request.resource.data.completedCount == (('completedCount' in resource.data) ? resource.data.completedCount : 0) + 1
            )
          )
          && (
            // 15% commission owed to BarberGo on a completed session — isolated write,
            // same tamper-proof +1 pattern as completedCount. totalCommissionsOwed's
            // delta is bounded to the max possible commission on a single appointment
            // (20000 DH price cap * 15% = 3000 DH), so several sessions' worth can't be
            // folded into one write.
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['unpaidCommissionsCount', 'totalCommissionsOwed'])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unpaidCommissionsCount', 'totalCommissionsOwed'])
              && request.resource.data.unpaidCommissionsCount == (('unpaidCommissionsCount' in resource.data) ? resource.data.unpaidCommissionsCount : 0) + 1
              && request.resource.data.totalCommissionsOwed > (('totalCommissionsOwed' in resource.data) ? resource.data.totalCommissionsOwed : 0)
              && request.resource.data.totalCommissionsOwed <= (('totalCommissionsOwed' in resource.data) ? resource.data.totalCommissionsOwed : 0) + 3000
            )
          )
        )
        || (isAdmin()
          && resource.data.role == 'barber'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['kycStatus'])
          && request.resource.data.kycStatus in ['unverified', 'pending', 'verified']
        )
        || (isAdmin()
          && resource.data.role == 'barber'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unpaidCommissionsCount', 'totalCommissionsOwed'])
          && request.resource.data.unpaidCommissionsCount == 0
          && request.resource.data.totalCommissionsOwed == 0
        )
        || (
          // profileViews ("visiteurs" shown on a pro's own Accueil) — any other signed-in
          // user viewing a barber's profile can bump it by exactly +1 in its own isolated
          // write, same tamper-proof pattern as completedCount above.
          isSignedIn()
          && request.auth.uid != userId
          && resource.data.role == 'barber'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileViews'])
          && request.resource.data.profileViews == (('profileViews' in resource.data) ? resource.data.profileViews : 0) + 1
        )
        || (
          // Real average rating ("note") shown on a pro's profile and on profile-list
          // rows — whoever just left a review can bump reviewCount by exactly +1 and
          // ratingSum by exactly their own review's rating (1-5, matching isValidReview),
          // in the same isolated write, same tamper-proof pattern as profileViews.
          isSignedIn()
          && request.auth.uid != userId
          && resource.data.role == 'barber'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewCount', 'ratingSum'])
          && request.resource.data.reviewCount == (('reviewCount' in resource.data) ? resource.data.reviewCount : 0) + 1
          && request.resource.data.ratingSum >= (('ratingSum' in resource.data) ? resource.data.ratingSum : 0) + 1
          && request.resource.data.ratingSum <= (('ratingSum' in resource.data) ? resource.data.ratingSum : 0) + 5
        );
    }

    // Admin allowlist — one document per admin UID, created manually in the Firebase
    // Console only (never writable by client code). A user may read their own doc to
    // decide whether to show the admin panel, but cannot list others or write at all.
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }

    // KYC dossiers (CIN + selfie URLs) — kept out of the public users/ document on
    // purpose. Only the barber themself and admins can read it.
    match /kycSubmissions/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidKycSubmission(request.resource.data);
    }

    // Services (Menu) — public so guests can browse prestations before signing in. This
    // is the legacy shared catalog (seed data + the client "Annonce" flow); real booking
    // now runs on each barber's own services list on their profile. Writes are limited
    // to barber accounts, not just any signed-in user.
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'barber'
        && isValidService(request.resource.data);
    }

    // Real visitor counters (daily + monthly) — public (guests must be counted too),
    // but write is restricted to a strict +1 delta on a single 'count' field so it can
    // never be tampered into an arbitrary number even without auth.
    match /stats/{statId} {
      allow read: if true;
      allow create: if statId.matches('^visits_[0-9]{4}-[0-9]{2}(-[0-9]{2})?$')
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if statId.matches('^visits_[0-9]{4}-[0-9]{2}(-[0-9]{2})?$')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count'])
        && request.resource.data.count == resource.data.count + 1;
    }

    // Real total user count (clients + pros) — one doc, incremented by exactly +1 right
    // after a new account is created, so the caller is always freshly signed in.
    match /stats/totalUsers {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count'])
        && request.resource.data.count == resource.data.count + 1;
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber');
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber');
      allow create: if isSignedIn() && isValidAppointment(request.resource.data);
      allow update: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid || resource.data.barberId == 'dummy_barber')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'totalPrice', 'proposedPrice', 'counterPriceByBarber', 'counterDateTime', 'dateTime', 'negotiationStatus', 'clientLocationShared', 'clientNotes', 'barberId'])
        && (!('totalPrice' in request.resource.data) || (isNum(request.resource.data.totalPrice) && request.resource.data.totalPrice > 0 && request.resource.data.totalPrice <= 20000))
        && (!('proposedPrice' in request.resource.data) || (isNum(request.resource.data.proposedPrice) && request.resource.data.proposedPrice > 0 && request.resource.data.proposedPrice <= 20000))
        && (!('counterPriceByBarber' in request.resource.data) || (isNum(request.resource.data.counterPriceByBarber) && request.resource.data.counterPriceByBarber > 0 && request.resource.data.counterPriceByBarber <= 20000))
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['barberId'])
          || (resource.data.barberId == 'dummy_barber' && request.resource.data.barberId == request.auth.uid)
        );
    }

    // Transactional email queue — the "Trigger Email from Firestore" extension (running
    // with Admin SDK privileges, so it bypasses these rules) reads docs here and sends
    // them, then marks them delivered. The client may only create well-formed docs, and
    // can never read back anyone's queued email (could contain another user's address).
    match /mail/{mailId} {
      allow create: if isSignedIn() && isValidMail(request.resource.data);
      allow read, update, delete: if false;
    }

    // Real per-post likes — one doc per post, keyed by a hash of (barberUid, photoUrl)
    // computed client-side (see hashPostId in useFirebase.ts). Public read (guests browse
    // likes counts too); liking requires being signed in, and each write can only move
    // the count by exactly +1/-1 while adding/removing exactly the caller's own uid from
    // likedBy — nobody can inflate a count or toggle another user's like.
    match /postLikes/{postId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['count', 'likedBy'])
        && request.resource.data.count == 1
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 1
        && request.resource.data.likedBy[0] == request.auth.uid;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'likedBy'])
        && (
          // Like: count +1, my uid added and nobody else's entry touched.
          (request.resource.data.count == resource.data.count + 1
            && !(request.auth.uid in resource.data.likedBy)
            && request.auth.uid in request.resource.data.likedBy
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1)
          ||
          // Unlike: count -1, my uid removed and nobody else's entry touched.
          (request.resource.data.count == resource.data.count - 1
            && request.auth.uid in resource.data.likedBy
            && !(request.auth.uid in request.resource.data.likedBy)
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1)
        );
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReview(request.resource.data);
      allow delete: if isSignedIn() && resource.data.clientId == request.auth.uid;
    }
  }
}
